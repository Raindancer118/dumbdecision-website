---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Logo from '../components/Logo.astro';
---

<Base title="Home">
  <Nav />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow"></div>
    <Logo variant="color" size={175} class="hero-logo" />
    <div class="hero-eyebrow">
      <span class="eyebrow-line"></span>
      Großraum Hamburg · Seit 2025
      <span class="eyebrow-line"></span>
    </div>
    <h1>Dumb Decision<br />TTRPG</h1>
    <p class="hero-subtitle">Wo die Würfel entscheiden —<br />und Geschichten in Erinnerung bleiben.</p>
    <p class="hero-desc">
      Ein gemeinnütziger TTRPG-Verein für Jugendliche und junge Erwachsene.
      Offen, inklusiv, und mit einer lebendigen Welt, die auf dich wartet.
    </p>
    <div class="cta-row">
      <a href="https://discord.gg/scUj3uw8zWt" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Discord beitreten</a>
      <a href="/ueber-uns" class="btn btn-ghost">Mehr erfahren</a>
    </div>
    <div class="hero-scroll-line"></div>
  </section>

  <div class="ornament">
    <div class="ornament-line"></div>
    <div class="ornament-glyph">✦</div>
    <div class="ornament-line"></div>
  </div>

  <!-- INTRO -->
  <section class="intro">
    <div class="intro-text">
      <div class="section-label">Was wir sind</div>
      <h2>Pen &amp; Paper als Gemeinschaft —<br />nicht nur als Hobby.</h2>
      <p class="intro-quote">
        „Es begann als eine Gruppe Freunde, die sich fest vornahm,
        jeden Mittwoch für D&amp;D zusammenzukommen."
      </p>
      <p class="intro-body">
        Heute ist Dumb Decision TTRPG ein Verein mit einer gemeinsamen Vision:
        einer lebendigen Welt, in der jede Kampagne zählt — und einem sicheren,
        offenen Ort für alle, die das Geschichtenerzählen lieben.
        Wir fördern Jugendhilfe, Bildung und Kreativität durch Pen-&amp;-Paper-Rollenspiele.
      </p>
      <a href="/ueber-uns" class="text-link">Unsere Geschichte →</a>
    </div>

    <div class="pillars">
      <div class="pillar">
        <div class="pillar-num">I</div>
        <h3>Zwei Systeme</h3>
        <p>D&amp;D 5.5E und Daggerheart by Critical Role — gespielt in derselben lebendigen Welt.</p>
      </div>
      <div class="pillar">
        <div class="pillar-num">II</div>
        <h3>Eine Welt, die lebt</h3>
        <p>Alle Kampagnen spielen in Caerathis. Was du erlebst, verändert die Welt für alle anderen.</p>
      </div>
      <div class="pillar">
        <div class="pillar-num">III</div>
        <h3>Offen für alle</h3>
        <p>Gemeinnützig und inklusiv — für Jugendliche und junge Erwachsene ab 14 Jahren.</p>
      </div>
    </div>
  </section>

  <!-- WORLD TEASER -->
  <section class="world-teaser">
    <div class="world-teaser-glow"></div>
    <div class="section-label">Unsere Welt</div>
    <h2 class="world-name">Caerathis</h2>
    <p class="world-desc">
      Tiefen Ozeane und verstreute Kontinente, schwebend in einem lebendigen
      und uralten Sternensystem. Eine Welt, die niemals aufhört, Geschichten zu erzählen.
    </p>
    <a href="/caerathis" class="text-link">Die Welt entdecken →</a>
  </section>

  <!-- PROJECT MYSTERIA -->
  <section class="mysteria">
    <div class="mysteria-inner">
      <div class="section-label">Die Vision</div>
      <h2>Project Mysteria</h2>
      <p>
        Unsere große Vision: mehrere Dungeon Master, viele Kampagnen, alle in Caerathis —
        eine lebendige Welt, die sich dynamisch verändert, egal ob du gerade spielst oder nicht.
        Verschiedene Abenteurergruppen, verschiedene Altersgruppen, eine gemeinsame Geschichte.
      </p>
      <a href="/ueber-uns#mysteria" class="text-link">Mehr über Project Mysteria →</a>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: calc(var(--nav-h) + 3rem) 2rem 5rem;
    position: relative;
  }
  .hero-glow {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 55% at 50% 50%, rgba(155,127,90,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-scroll-line {
    position: absolute; bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 1px; height: 90px;
    background: linear-gradient(to bottom, var(--parch), transparent);
  }
  .hero-logo {
    margin-bottom: 2.5rem;
    filter: drop-shadow(0 0 50px rgba(155,127,90,0.28));
  }
  .hero-eyebrow {
    display: flex; align-items: center; gap: 1.2rem;
    color: var(--parch);
    font-size: 0.68rem; letter-spacing: 0.32em; text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .eyebrow-line {
    display: block; width: 45px; height: 1px;
    background: var(--parch); opacity: 0.45;
  }
  h1 {
    font-size: clamp(3.2rem, 9vw, 6.5rem);
    letter-spacing: 0.01em; margin-bottom: 0.6rem;
  }
  .hero-subtitle {
    font-family: 'EB Garamond', serif; font-style: italic;
    font-size: clamp(1.05rem, 2.5vw, 1.4rem);
    color: var(--dim); margin-bottom: 2rem; line-height: 1.5;
  }
  .hero-desc {
    font-size: 0.92rem; color: var(--dim);
    max-width: 440px; line-height: 1.85; margin-bottom: 3rem;
  }
  .cta-row { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }

  /* ── INTRO ── */
  .intro {
    max-width: var(--max-w); margin: 0 auto;
    padding: 0 var(--section-px) 8rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 7rem; align-items: start;
  }
  .intro h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); margin-bottom: 1.5rem; line-height: 1.25; }
  .intro-quote {
    font-family: 'EB Garamond', serif; font-style: italic;
    font-size: 1.15rem; color: var(--dim);
    margin-bottom: 1.25rem; line-height: 1.65;
  }
  .intro-body { font-size: 0.9rem; color: var(--dim); line-height: 1.85; margin-bottom: 2rem; }
  .pillars { display: flex; flex-direction: column; gap: 2px; }
  .pillar {
    background: var(--bg2); border: 1px solid var(--border);
    padding: 2rem 2.5rem; transition: border-color 0.25s;
  }
  .pillar:hover { border-color: rgba(155,127,90,0.38); }
  .pillar-num {
    font-family: 'EB Garamond', serif; font-size: 0.72rem;
    letter-spacing: 0.2em; color: var(--parch); opacity: 0.5; margin-bottom: 0.6rem;
  }
  .pillar h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
  .pillar p { font-size: 0.875rem; color: var(--dim); }

  /* ── WORLD TEASER ── */
  .world-teaser {
    background: var(--bg2);
    border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    padding: 8rem var(--section-px);
    text-align: center; position: relative; overflow: hidden;
  }
  .world-teaser-glow {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(155,127,90,0.05) 0%, transparent 70%);
    pointer-events: none;
  }
  .world-name {
    font-size: clamp(3rem, 8vw, 6rem);
    letter-spacing: 0.08em; margin-bottom: 1.5rem; position: relative;
  }
  .world-desc {
    font-family: 'EB Garamond', serif; font-style: italic;
    font-size: clamp(1rem, 2vw, 1.25rem); color: var(--dim);
    max-width: 560px; margin: 0 auto 2.5rem; line-height: 1.7; position: relative;
  }
  .world-teaser .text-link { position: relative; }

  /* ── PROJECT MYSTERIA ── */
  .mysteria { padding: 7rem var(--section-px); }
  .mysteria-inner { max-width: 640px; margin: 0 auto; }
  .mysteria h2 { font-size: clamp(2rem, 4vw, 2.8rem); margin-bottom: 1.5rem; }
  .mysteria p { font-size: 0.92rem; color: var(--dim); line-height: 1.85; margin-bottom: 2rem; }

  @media (max-width: 860px) {
    .intro { grid-template-columns: 1fr; gap: 4rem; }
  }

  @media (max-width: 640px) {
    .hero { padding-left: var(--section-px); padding-right: var(--section-px); }
    .hero-desc { margin-bottom: 2.5rem; }
    .cta-row { flex-direction: column; align-items: stretch; }
    .cta-row .btn { text-align: center; }
    .intro { padding-bottom: 5rem; gap: 3rem; }
    .pillar { padding: 1.5rem; }
    .world-teaser { padding: 5rem var(--section-px); }
    .world-name { letter-spacing: 0.04em; }
    .mysteria { padding: 5rem var(--section-px); }
  }
</style>
