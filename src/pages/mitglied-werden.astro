---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Base
  title="Mitglied werden"
  description="Werde Teil von Dumb Decision TTRPG — füll die Vereinsanmeldung aus und tritt unserer Community bei."
>
  <Nav />

  <PageHeader
    label="Mitglied werden"
    title="Dein Platz am Tisch."
    subtitle="Füll das Formular aus und werde Teil von Dumb Decision TTRPG. Wir melden uns, sobald der Vorstand deinen Antrag geprüft hat."
    ghost="Beitritt"
  />

  <section class="membership-section">
    <div class="membership-inner">

      <!-- ── FORM (shown by default) ── -->
      <div id="formWrap">

        <div class="form-preamble">
          <p class="preamble-text">
            Die Anmeldung ist verbindlich und richtet sich an Personen ab&nbsp;16&nbsp;Jahren.
            Nach Eingang deiner Anfrage erhältst du innerhalb weniger Tage eine Rückmeldung vom Vorstand.
          </p>
        </div>

        <form id="membershipForm" novalidate>

          <!-- ── 1. Persönliche Daten ── -->
          <div class="form-section">
            <div class="section-label">Persönliche Daten</div>

            <div class="field-row">
              <div class="field">
                <label for="vorname">Vorname <span class="req">*</span></label>
                <input type="text" id="vorname" name="vorname" autocomplete="given-name"
                  placeholder="Vorname" required />
                <span class="field-hint" id="vorname-hint"></span>
              </div>
              <div class="field">
                <label for="nachname">Nachname <span class="req">*</span></label>
                <input type="text" id="nachname" name="nachname" autocomplete="family-name"
                  placeholder="Nachname" required />
                <span class="field-hint" id="nachname-hint"></span>
              </div>
            </div>

            <div class="field field--narrow">
              <label for="geburtsdatum">Geburtsdatum <span class="req">*</span></label>
              <input type="date" id="geburtsdatum" name="geburtsdatum"
                autocomplete="bday" required />
            </div>

            <div class="field address-wrap">
              <label for="strasse">Straße &amp; Hausnummer <span class="req">*</span></label>
              <input type="text" id="strasse" name="strasse" autocomplete="off"
                placeholder="Musterstraße 42" required />
              <ul id="addressSuggestions" class="addr-suggestions" hidden></ul>
            </div>

            <div class="field-row">
              <div class="field field--plz">
                <label for="plz">PLZ <span class="req">*</span></label>
                <input type="text" id="plz" name="plz" autocomplete="postal-code"
                  placeholder="20095" pattern="\d{5}" maxlength="5" required />
              </div>
              <div class="field">
                <label for="ort">Ort <span class="req">*</span></label>
                <input type="text" id="ort" name="ort" autocomplete="address-level2"
                  placeholder="Hamburg" required />
              </div>
            </div>
          </div>

          <div class="ornament" aria-hidden="true">
            <div class="ornament-line"></div>
            <div class="ornament-glyph">✦</div>
            <div class="ornament-line"></div>
          </div>

          <!-- ── 2. Kontakt & Community ── -->
          <div class="form-section">
            <div class="section-label">Kontakt &amp; Community</div>

            <!-- Email + OTP -->
            <div class="field">
              <label for="email">E-Mail-Adresse <span class="req">*</span></label>
              <div class="email-row">
                <input type="email" id="email" name="email" autocomplete="email"
                  placeholder="deine@email.de" required />
                <button type="button" id="sendOtpBtn" class="btn btn-ghost btn-otp">
                  Code senden
                </button>
              </div>
            </div>

            <div class="field otp-field" id="otpField" hidden>
              <label for="otp">Bestätigungscode <span class="req">*</span></label>
              <div class="otp-row">
                <input type="text" id="otp" name="otp" inputmode="numeric"
                  pattern="\d{6}" maxlength="6" placeholder="_ _ _ _ _ _"
                  autocomplete="one-time-code" />
                <span class="otp-status" id="otpStatus" aria-live="polite"></span>
              </div>
              <span class="field-hint dim" id="otpHint">
                Kein Code erhalten?
                <button type="button" id="resendOtpBtn" class="link-btn">Erneut senden</button>
              </span>
            </div>

            <div class="field-row">
              <div class="field">
                <label for="telefon">Telefon <span class="opt">(optional)</span></label>
                <input type="tel" id="telefon" name="telefon" autocomplete="tel"
                  placeholder="+49 40 000000" />
              </div>
              <div class="field">
                <label for="discord">Discord-Username <span class="opt">(optional)</span></label>
                <input type="text" id="discord" name="discord"
                  placeholder="username" autocomplete="off" />
              </div>
            </div>
          </div>

          <div class="ornament" aria-hidden="true">
            <div class="ornament-line"></div>
            <div class="ornament-glyph">✦</div>
            <div class="ornament-line"></div>
          </div>

          <!-- ── 3. Über dich ── -->
          <div class="form-section">
            <div class="section-label">Über dich</div>

            <div class="field field--narrow">
              <label for="erfahrung">TTRPG-Erfahrung <span class="req">*</span></label>
              <div class="select-wrap">
                <select id="erfahrung" name="erfahrung" required>
                  <option value="" disabled selected>Bitte auswählen …</option>
                  <option value="anfaenger">Anfänger — noch keine Erfahrung</option>
                  <option value="gelegenheit">Gelegenheitsspieler — ein paar Sessions</option>
                  <option value="erfahren">Erfahren — mehrere Kampagnen gespielt</option>
                  <option value="veteran">Veteran — langjährige TTRPG-Erfahrung</option>
                </select>
                <span class="select-arrow" aria-hidden="true">↓</span>
              </div>
            </div>

            <div class="field">
              <label for="aufmerksam">Wie bist du auf uns aufmerksam geworden? <span class="opt">(optional)</span></label>
              <input type="text" id="aufmerksam" name="aufmerksam"
                placeholder="z.B. YouTube, Empfehlung, Social Media …" />
            </div>

            <div class="field">
              <label for="motivation">Warum möchtest du Mitglied werden? <span class="req">*</span></label>
              <textarea id="motivation" name="motivation" rows="5"
                placeholder="Erzähl uns ein bisschen über dich und deine Motivation …"
                required></textarea>
            </div>
          </div>

          <div class="ornament" aria-hidden="true">
            <div class="ornament-line"></div>
            <div class="ornament-glyph">✦</div>
            <div class="ornament-line"></div>
          </div>

          <div class="ornament" aria-hidden="true">
            <div class="ornament-line"></div>
            <div class="ornament-glyph">✦</div>
            <div class="ornament-line"></div>
          </div>

          <!-- ── 4. Einwilligungen ── -->
          <div class="form-section">
            <div class="section-label">Medien &amp; Einwilligungen</div>
            <p class="consent-intro">
              Diese Einwilligungen sind freiwillig und für die Mitgliedschaft nicht erforderlich.
              Du kannst sie jederzeit widerrufen.
            </p>

            <div class="opt-group">
              <p class="opt-group-label">Live-Streaming</p>
              <label class="opt-label" for="streamingVideo">
                <input type="checkbox" id="streamingVideo" name="streamingVideo" />
                <span>Ich bin einverstanden, dass Kampagnen, an denen ich teilnehme, mit <strong>Video- und Audiofeed</strong> live übertragen werden dürfen (z.&nbsp;B. auf Twitch).</span>
              </label>
              <label class="opt-label" for="streamingAudio">
                <input type="checkbox" id="streamingAudio" name="streamingAudio" />
                <span>Ich bin einverstanden, dass Kampagnen, an denen ich teilnehme, <strong>ohne Videobild, aber mit Audiofeed</strong> live übertragen werden dürfen.</span>
              </label>
            </div>

            <div class="opt-group">
              <p class="opt-group-label">Podcast</p>
              <label class="opt-label" for="podcast">
                <input type="checkbox" id="podcast" name="podcast" />
                <span>Ich bin einverstanden, dass <strong>Audioaufnahmen meiner Stimme</strong> in Podcast-Formaten des Vereins verwendet werden dürfen.</span>
              </label>
            </div>

            <div class="opt-group">
              <p class="opt-group-label">Sonstiges</p>
              <label class="opt-label" for="emailDigital">
                <input type="checkbox" id="emailDigital" name="emailDigital" />
                <span>Ich möchte Einladungen zur Mitgliederversammlung und wichtige Vereinsinformationen <strong>per E-Mail</strong> erhalten (spart Porto).</span>
              </label>
              <label class="opt-label" for="photoConsent">
                <input type="checkbox" id="photoConsent" name="photoConsent" />
                <span>Ich erteile mein Einverständnis zur Verwendung von <strong>Fotos/Bildern meiner Person</strong> auf der Vereinswebsite oder in Vereinspublikationen.</span>
              </label>
            </div>
          </div>

          <div class="ornament" aria-hidden="true">
            <div class="ornament-line"></div>
            <div class="ornament-glyph">✦</div>
            <div class="ornament-line"></div>
          </div>

          <!-- ── 5. Unterschrift & Bestätigung ── -->
          <div class="form-section form-section--submit">

            <label class="consent-label" for="consent">
              <input type="checkbox" id="consent" name="consent" required />
              <span class="consent-text">
                Ich stimme der
                <a href="/satzung" class="text-link" target="_blank" rel="noopener">Vereinssatzung</a>
                und der
                <a href="/datenschutz" class="text-link" target="_blank" rel="noopener">Datenschutzerklärung</a>
                zu und erkläre mich mit der Verarbeitung meiner Daten für Vereinszwecke einverstanden.
              </span>
            </label>

            <!-- Digitale Unterschrift -->
            <div class="signature-block">
              <div class="sig-place-date" id="sigPlaceDate"></div>
              <div class="field">
                <label for="unterschrift">Unterschrift <span class="req">*</span></label>
                <input type="text" id="unterschrift" name="unterschrift"
                  placeholder="Vor- und Nachname eintippen …"
                  autocomplete="name" required />
              </div>
              <div class="sig-preview" id="sigPreview" aria-hidden="true"></div>
              <p class="sig-legal">
                Mit der Eingabe deines Namens bestätigst du, dass alle Angaben korrekt sind.
                Diese digitale Unterschrift ist <strong>rechtlich verbindlich</strong>.
              </p>
            </div>

            <div id="formError" class="form-notice form-notice--err" hidden></div>

            <button type="submit" id="submitBtn" class="btn btn-primary btn-submit" disabled>
              Anmeldung absenden
            </button>

            <p class="submit-note">
              * Pflichtfeld — deine Anmeldung wird dem Vorstand zur Prüfung vorgelegt.
            </p>
          </div>

        </form>
      </div><!-- /formWrap -->

      <!-- ── SUCCESS STATE ── -->
      <div id="successWrap" hidden>
        <div class="success-card">
          <div class="success-glyph" aria-hidden="true">✦</div>
          <div class="section-label">Anmeldung eingegangen</div>
          <h2>Willkommen an Bord.</h2>
          <p>
            Deine Vereinsanmeldung wurde erfolgreich übermittelt. Der Vorstand wird sie in den nächsten Tagen prüfen
            und sich per E-Mail bei dir melden.
          </p>
          <p class="success-hint">
            Schau gerne auch schon mal in unserem
            <a href="/kontakt" class="text-link">Kontaktbereich</a> vorbei —
            sobald du aufgenommen wurdest, erhältst du deinen persönlichen Discord-Einladungslink.
          </p>
        </div>
      </div>

    </div><!-- /membership-inner -->
  </section>

  <Footer />
</Base>

<script>
  // ── State ──────────────────────────────────────────────────────────────────
  let otpSent        = false;
  let emailForOtp    = '';

  // ── Elements ───────────────────────────────────────────────────────────────
  const form        = document.getElementById('membershipForm') as HTMLFormElement;
  const sendBtn     = document.getElementById('sendOtpBtn')    as HTMLButtonElement;
  const resendBtn   = document.getElementById('resendOtpBtn')  as HTMLButtonElement;
  const otpField    = document.getElementById('otpField')      as HTMLDivElement;
  const otpInput    = document.getElementById('otp')           as HTMLInputElement;
  const otpStatus   = document.getElementById('otpStatus')     as HTMLSpanElement;
  const emailInput  = document.getElementById('email')         as HTMLInputElement;
  const submitBtn   = document.getElementById('submitBtn')     as HTMLButtonElement;
  const formError   = document.getElementById('formError')     as HTMLDivElement;
  const consentBox  = document.getElementById('consent')       as HTMLInputElement;
  const formWrap    = document.getElementById('formWrap')      as HTMLDivElement;
  const successWrap = document.getElementById('successWrap')   as HTMLDivElement;

  // ── Address autocomplete (Photon / OSM) ───────────────────────────────────
  const strasseInput    = document.getElementById('strasse')            as HTMLInputElement;
  const plzInput        = document.getElementById('plz')               as HTMLInputElement;
  const ortInput        = document.getElementById('ort')               as HTMLInputElement;
  const suggestionsList = document.getElementById('addressSuggestions') as HTMLUListElement;

  interface PhotonFeature {
    properties: {
      name?: string;
      street?: string;
      housenumber?: string;
      postcode?: string;
      city?: string;
      town?: string;
      village?: string;
    };
  }

  function addrCity(p: PhotonFeature['properties']): string {
    return p.city ?? p.town ?? p.village ?? '';
  }

  function buildLabel(p: PhotonFeature['properties']): string {
    const street = p.street ?? p.name ?? '';
    const num    = p.housenumber ? ` ${p.housenumber}` : '';
    const city   = addrCity(p);
    const plz    = p.postcode ?? '';
    return [street + num, plz && city ? `${plz} ${city}` : city || plz].filter(Boolean).join(', ');
  }

  let _addrTimer: ReturnType<typeof setTimeout>;

  function hideSuggestions() {
    suggestionsList.hidden = true;
    suggestionsList.innerHTML = '';
  }

  async function fetchSuggestions(q: string) {
    if (q.length < 3) { hideSuggestions(); return; }
    try {
      const res  = await fetch(`/api/address-lookup?q=${encodeURIComponent(q)}`);
      if (!res.ok) return;
      const data = await res.json() as { features: PhotonFeature[] };

      const hits = data.features.filter(f => f.properties.street ?? f.properties.name);
      if (!hits.length) { hideSuggestions(); return; }

      suggestionsList.innerHTML = '';
      hits.forEach(feat => {
        const p   = feat.properties;
        const li  = document.createElement('li');
        li.className = 'addr-item';
        li.tabIndex = 0;
        li.textContent = buildLabel(p);
        li.addEventListener('mousedown', (e) => {
          e.preventDefault();
          const street = p.street ?? p.name ?? '';
          const num    = p.housenumber ? ` ${p.housenumber}` : '';
          strasseInput.value = street + num;
          if (p.postcode) plzInput.value = p.postcode.slice(0, 5);
          const city = addrCity(p);
          if (city) ortInput.value = city;
          hideSuggestions();
        });
        suggestionsList.appendChild(li);
      });
      suggestionsList.hidden = false;
    } catch { /* network error — fail silently */ }
  }

  strasseInput.addEventListener('input', () => {
    clearTimeout(_addrTimer);
    _addrTimer = setTimeout(() => fetchSuggestions(strasseInput.value.trim()), 300);
  });
  strasseInput.addEventListener('blur', () => setTimeout(hideSuggestions, 150));
  strasseInput.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') hideSuggestions();
    if (e.key === 'ArrowDown') {
      const first = suggestionsList.querySelector('.addr-item') as HTMLElement | null;
      first?.focus();
      e.preventDefault();
    }
  });

  // keyboard nav inside suggestion list
  suggestionsList.addEventListener('keydown', (e) => {
    const items = [...suggestionsList.querySelectorAll<HTMLElement>('.addr-item')];
    const idx   = items.indexOf(document.activeElement as HTMLElement);
    if (e.key === 'ArrowDown') { items[idx + 1]?.focus(); e.preventDefault(); }
    if (e.key === 'ArrowUp')   { idx > 0 ? items[idx - 1]?.focus() : strasseInput.focus(); e.preventDefault(); }
    if (e.key === 'Enter')     { (document.activeElement as HTMLElement)?.dispatchEvent(new MouseEvent('mousedown')); e.preventDefault(); }
    if (e.key === 'Escape')    { hideSuggestions(); strasseInput.focus(); }
  });

  // PLZ → Ort auto-fill
  plzInput.addEventListener('input', async () => {
    const plz = plzInput.value.trim();
    if (plz.length !== 5 || !/^\d{5}$/.test(plz)) return;
    if (ortInput.value.trim()) return; // don't overwrite manual entry
    try {
      const res  = await fetch(`/api/address-lookup?plz=${plz}`);
      if (!res.ok) return;
      const data = await res.json() as { city?: string | null };
      if (data.city) ortInput.value = data.city;
    } catch { /* fail silently */ }
  });

  // ── Name sanity check ──────────────────────────────────────────────────────
  const NAME_RE = /^[\p{L}\p{M}][\p{L}\p{M} '\-]*[\p{L}\p{M}]$|^[\p{L}\p{M}]{2}$/u;

  function checkName(id: string, hintId: string) {
    const input = document.getElementById(id) as HTMLInputElement;
    const hint  = document.getElementById(hintId) as HTMLSpanElement;
    input.addEventListener('blur', () => {
      const val = input.value.trim();
      if (!val) { hint.textContent = ''; return; }
      if (!NAME_RE.test(val) || val.length < 2) {
        hint.textContent = 'Bitte gib deinen echten Namen ein.';
        hint.className = 'field-hint err';
      } else {
        hint.textContent = '';
        hint.className = 'field-hint';
      }
    });
  }
  checkName('vorname', 'vorname-hint');
  checkName('nachname', 'nachname-hint');

  // ── Signature ──────────────────────────────────────────────────────────────
  const sigInput     = document.getElementById('unterschrift') as HTMLInputElement;
  const sigPreview   = document.getElementById('sigPreview')   as HTMLDivElement;
  const sigPlaceDate = document.getElementById('sigPlaceDate') as HTMLDivElement;

  // Auto-fill Ort + Datum
  function updatePlaceDate() {
    const ort  = ortInput.value.trim();
    const date = new Date().toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
    sigPlaceDate.textContent = ort ? `${ort}, ${date}` : date;
  }
  ortInput.addEventListener('input', updatePlaceDate);
  updatePlaceDate();

  sigInput.addEventListener('input', () => {
    sigPreview.textContent = sigInput.value || '';
    updateSubmit();
  });

  // ── OTP submit-button gating ────────────────────────────────────────────────
  function updateSubmit() {
    const ready = otpSent
      && otpInput.value.trim().length === 6
      && consentBox.checked
      && sigInput.value.trim().length >= 2;
    submitBtn.disabled = !ready;
  }

  otpInput.addEventListener('input', updateSubmit);
  consentBox.addEventListener('change', updateSubmit);

  // Re-enable OTP send if email changes
  emailInput.addEventListener('input', () => {
    if (otpSent && emailInput.value.trim().toLowerCase() !== emailForOtp) {
      otpSent = false;
      otpField.hidden = true;
      sendBtn.textContent = 'Code senden';
      sendBtn.disabled = false;
      updateSubmit();
    }
  });

  // ── Send OTP ───────────────────────────────────────────────────────────────
  async function doSendOtp() {
    const email = emailInput.value.trim().toLowerCase();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailInput.focus();
      return;
    }

    sendBtn.disabled = true;
    sendBtn.textContent = 'Sende …';

    const res = await fetch('/api/membership/send-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email }),
    });

    if (res.ok) {
      emailForOtp = email;
      otpSent = true;
      otpField.hidden = false;
      otpInput.value = '';
      sendBtn.textContent = 'Erneut senden';
      sendBtn.disabled = false;
      otpStatus.textContent = '';
      otpInput.focus();
    } else {
      const data = await res.json() as { error?: string };
      sendBtn.textContent = 'Code senden';
      sendBtn.disabled = false;
      otpStatus.textContent = data.error ?? 'Fehler beim Senden.';
      otpStatus.className = 'otp-status err';
    }
  }

  sendBtn.addEventListener('click', doSendOtp);
  resendBtn.addEventListener('click', doSendOtp);

  // ── Show / hide error ───────────────────────────────────────────────────────
  function showError(msg: string) {
    formError.textContent = msg;
    formError.hidden = false;
    formError.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  function clearError() {
    formError.hidden = true;
    formError.textContent = '';
  }

  // ── Form submit ─────────────────────────────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearError();

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird gesendet …';

    const payload = {
      vorname:     (document.getElementById('vorname')    as HTMLInputElement).value.trim(),
      nachname:    (document.getElementById('nachname')   as HTMLInputElement).value.trim(),
      geburtsdatum:(document.getElementById('geburtsdatum') as HTMLInputElement).value,
      email:       emailInput.value.trim().toLowerCase(),
      telefon:     (document.getElementById('telefon')   as HTMLInputElement).value.trim() || undefined,
      strasse:     (document.getElementById('strasse')   as HTMLInputElement).value.trim(),
      plz:         (document.getElementById('plz')       as HTMLInputElement).value.trim(),
      ort:         (document.getElementById('ort')       as HTMLInputElement).value.trim(),
      discord:        (document.getElementById('discord')   as HTMLInputElement).value.trim() || undefined,
      erfahrung:      (document.getElementById('erfahrung') as HTMLSelectElement).value,
      aufmerksam:     (document.getElementById('aufmerksam') as HTMLInputElement).value.trim() || undefined,
      motivation:     (document.getElementById('motivation') as HTMLTextAreaElement).value.trim(),
      streamingVideo: (document.getElementById('streamingVideo') as HTMLInputElement).checked,
      streamingAudio: (document.getElementById('streamingAudio') as HTMLInputElement).checked,
      podcast:        (document.getElementById('podcast')        as HTMLInputElement).checked,
      emailDigital:   (document.getElementById('emailDigital')   as HTMLInputElement).checked,
      photoConsent:   (document.getElementById('photoConsent')   as HTMLInputElement).checked,
      unterschrift:   sigInput.value.trim(),
      otp:            otpInput.value.trim(),
    };

    const res = await fetch('/api/membership/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      formWrap.hidden = true;
      successWrap.hidden = false;
      successWrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
      const data = await res.json() as { error?: string };
      showError(data.error ?? 'Ein Fehler ist aufgetreten. Bitte versuch es erneut.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Anmeldung absenden';
    }
  });
</script>

<style>
  .membership-section {
    padding: 6rem var(--section-px) 9rem;
  }
  .membership-inner {
    max-width: 660px;
    margin: 0 auto;
  }

  /* ── Preamble ── */
  .form-preamble {
    margin-bottom: 3.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }
  .preamble-text {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--dim);
    line-height: 1.8;
  }

  /* ── Form sections ── */
  .form-section {
    margin-bottom: 0;
  }
  .form-section .section-label {
    margin-bottom: 2rem;
  }

  /* ── Fields ── */
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .field--narrow { max-width: 300px; }
