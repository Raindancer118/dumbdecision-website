---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import { versions, type Item } from '../data/satzung';

const requestedId = Astro.url.searchParams.get('v');
const current     = requestedId
  ? (versions.find(v => v.id === requestedId) ?? versions[0]!)
  : versions[0]!;
const archive     = versions.filter(v => v.id !== current.id);
const isArchived  = current.id !== versions[0]!.id;

function renderItem(item: Item): string {
  if (typeof item === 'string') return item;
  const subs = item.sub.map(s => `<li>${s}</li>`).join('');
  return `${item.text}<ul class="sub-list">${subs}</ul>`;
}
---

<Base
  title="Vereinssatzung"
  description="Satzung des Dumb Decision TTRPG e.V."
>
  <Nav />

  <PageHeader
    label="Rechtliches"
    title="Vereinssatzung"
    ghost="Satzung"
  />

  <section class="legal-section">
    <div class="legal-inner">

      {/* Archive notice */}
      {isArchived && (
        <div class="legal-notice legal-notice--warn">
          <span class="section-label">Archivierte Version</span>
          <p>
            Du siehst eine ältere Version der Satzung ({current.label}, {current.date}).
            <a href="/satzung" class="text-link">Zur aktuellen Version →</a>
          </p>
        </div>
      )}

      {/* Archive buttons */}
      {(archive.length > 0 || isArchived) && (
        <div class="archive-bar">
          <span class="archive-label">Versionen</span>
          <div class="archive-btns">
            <a
              href="/satzung"
              class={`archive-btn${!isArchived ? ' archive-btn--active' : ''}`}
            >
              {versions[0]!.label}
              <span class="archive-date">{versions[0]!.date}</span>
            </a>
            {archive.map(v => (
              <a
                href={`/satzung?v=${v.id}`}
                class={`archive-btn${current.id === v.id ? ' archive-btn--active' : ''}`}
              >
                {v.label}
                <span class="archive-date">{v.date}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      {/* Current sections */}
      {current.sections.map(section => (
        <div class="legal-block">
          <h2>{section.heading}</h2>
          {section.intro && <p>{section.intro}</p>}
          <ol>
            {section.items.map(item => (
              <li set:html={renderItem(item)} />
            ))}
          </ol>
        </div>
      ))}

    </div>
  </section>

  <Footer />
</Base>

<style>
  .legal-section {
    padding: 5rem var(--section-px) 9rem;
  }
  .legal-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  /* ── Notices ── */
  .legal-notice {
    border: 1px solid var(--border);
    border-left: 3px solid var(--gold);
    padding: 1.25rem 1.75rem;
    background: var(--bg2);
  }
  .legal-notice--warn { border-left-color: #8a5a2a; }
  .legal-notice .section-label { margin-bottom: 0.5rem; }
  .legal-notice p {
    font-size: 0.88rem;
    line-height: 1.75;
    color: var(--dim);
    margin: 0;
  }

  /* ── Archive bar ── */
  .archive-bar {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .archive-label {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--parch);
  }
  .archive-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .archive-btn {
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.6rem 1.1rem;
    border: 1px solid var(--border);
    background: var(--bg2);
    color: var(--dim);
    text-decoration: none;
    font-size: 0.78rem;
    transition: border-color 0.2s, color 0.2s;
  }
  .archive-btn:hover {
    border-color: var(--parch);
    color: var(--text);
  }
  .archive-btn--active {
    border-color: var(--gold);
    color: var(--parch-lt);
    background: rgba(201,146,42,.07);
  }
  .archive-date {
    font-size: 0.68rem;
    color: var(--dim);
    opacity: 0.7;
  }

  /* ── Content ── */
  .legal-block h2 {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .legal-block p {
    font-size: 0.92rem;
    line-height: 1.85;
    color: var(--dim);
    margin-bottom: 0.5rem;
  }
  .legal-block ol {
    margin: 0.5rem 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: decimal;
  }
  .legal-block li {
    font-size: 0.92rem;
    line-height: 1.75;
    color: var(--dim);
  }
  .legal-block :global(.sub-list) {
    margin: 0.4rem 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    list-style: disc;
  }
  .legal-block strong { color: var(--parch-lt); font-weight: 600; }
</style>
