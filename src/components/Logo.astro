---
export interface Props {
  variant?: 'color' | 'white' | 'black';
  size?: number;
  class?: string;
  alt?: string;
}

const {
  variant = 'color',
  size = 175,
  class: className = '',
  alt = 'Dumb Decision TTRPG Logo',
} = Astro.props;

const lqip: Record<string, string> = {
  color: 'data:image/png;base64,',
  white: 'data:image/png;base64,',
  black: 'data:image/png;base64,',
};

const realSrc: Record<string, string> = {
  color: '/logo-color.webp',
  white: '/logo-white.webp',
  black: '/logo-black.webp',
};
const fallbackSrc: Record<string, string> = {
  color: '/logo-color-opt.png',
  white: '/logo-white-opt.png',
  black: '/logo-black-opt.png',
};

const id = `logo-${Math.random().toString(36).slice(2, 8)}`;
---

<div class:list={['logo-wrap', className]} style={`width:${size}px;height:${size}px`} id={id}>
  <!-- LQIP placeholder — blurred, shown immediately -->
  <img
    class="logo-lqip"
    src={lqip[variant]}
    aria-hidden="true"
    width={size}
    height={size}
    alt=""
  />
  <!-- Real image — fades in once loaded -->
  <picture class="logo-real">
    <source srcset={realSrc[variant]} type="image/webp" />
    <img
      src={fallbackSrc[variant]}
      alt={alt}
      width={size}
      height={size}
      fetchpriority="high"
      decoding="async"
    />
  </picture>
</div>

<script define:vars={{ id }}>
  const wrap = document.getElementById(id);
  if (wrap) {
    const real = wrap.querySelector('.logo-real img');
    const lqip = wrap.querySelector('.logo-lqip');
    if (real && real instanceof HTMLImageElement) {
      const reveal = () => {
        wrap.classList.add('loaded');
      };
      if (real.complete) {
        reveal();
      } else {
        real.addEventListener('load', reveal, { once: true });
      }
    }
  }
</script>

<style>
  .logo-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .logo-lqip,
  .logo-real {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .logo-lqip {
    object-fit: contain;
    filter: blur(8px);
    transform: scale(1.05);
    transition: opacity 0.4s ease;
    z-index: 1;
  }

  .logo-real {
    z-index: 2;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .logo-real img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* When loaded: real fades in, lqip fades out */
  .logo-wrap.loaded .logo-real {
    opacity: 1;
  }
  .logo-wrap.loaded .logo-lqip {
    opacity: 0;
  }
</style>
