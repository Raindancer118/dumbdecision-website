---
const socials = [
  { label: 'Discord', href: 'https://discord.gg/scUj3uw8zWt' },
  { label: 'YouTube', href: 'https://www.youtube.com/@dumbdecisionttrpg' },
  { label: 'Twitch',  href: 'https://www.twitch.tv/dumbdecision' },
  { label: 'Instagram', href: 'https://www.instagram.com/dumbdecisionttrpg' },
];
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="brand-name">Dumb Decision TTRPG</span>
      <span class="brand-tagline">Großraum Hamburg · Seit 2025</span>
    </div>

    <nav class="footer-nav" aria-label="Footer Navigation">
      <a href="/ueber-uns">Über Uns</a>
      <a href="/caerathis">Caerathis</a>
      <a href="/kontakt">Kontakt</a>
    </nav>

    <div class="footer-socials">
      {socials.map(s => (
        <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label}</a>
      ))}
    </div>
  </div>

  <div class="footer-bottom">
    <span>© {year} Dumb Decision TTRPG</span>
    <span class="footer-sep">·</span>
    <a href="mailto:vorstand@dumbdecision.de">vorstand@dumbdecision.de</a>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 4rem var(--section-px) 2rem;
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto 3rem;
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 4rem;
    align-items: start;
  }

  .brand-name {
    display: block;
    font-family: 'EB Garamond', serif;
    font-size: 1.05rem;
    letter-spacing: 0.15em;
    color: var(--parch-lt);
    margin-bottom: 0.5rem;
  }
  .brand-tagline {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    color: var(--dim);
    text-transform: uppercase;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .footer-nav a {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
    text-decoration: none;
    transition: color 0.25s;
  }
  .footer-nav a:hover { color: var(--parch-lt); }

  .footer-socials {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-end;
  }
  .footer-socials a {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
    text-decoration: none;
    transition: color 0.25s;
  }
  .footer-socials a:hover { color: var(--parch-lt); }

  .footer-bottom {
    max-width: var(--max-w);
    margin: 0 auto;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.72rem;
    color: var(--dim);
    opacity: 0.55;
  }
  .footer-bottom a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.25s;
  }
  .footer-bottom a:hover { opacity: 1; }
  .footer-sep { opacity: 0.4; }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .footer-socials { align-items: flex-start; }
  }
</style>
