---
const links = [
  { href: '/ueber-uns',       label: 'Über Uns' },
  { href: '/caerathis',       label: 'Caerathis' },
  { href: '/mitglied-werden', label: 'Mitglied werden' },
  { href: '/kontakt',         label: 'Kontakt' },
];
const current = Astro.url.pathname;
---

<nav>
  <a href="/" class="nav-brand">Dumb Decision TTRPG</a>
  <button class="nav-toggle" id="navToggle" aria-label="Menü öffnen">
    <span></span><span></span><span></span>
  </button>
  <ul class="nav-links" id="navLinks">
    {links.map(l => (
      <li>
        <a href={l.href} class:list={[{ active: current.startsWith(l.href) }]}>
          {l.label}
        </a>
      </li>
    ))}
    <li class="nav-discord">
      <a href="https://discord.gg/scUj3uw8zWt" target="_blank" rel="noopener noreferrer">
        Discord ↗
      </a>
    </li>
  </ul>
</nav>

<script>
  const toggle = document.getElementById('navToggle');
  const links  = document.getElementById('navLinks');
  toggle?.addEventListener('click', () => {
    links?.classList.toggle('open');
    toggle.classList.toggle('open');
  });
</script>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: var(--nav-h);
    padding: 0 var(--section-px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(to bottom, rgba(12, 9, 4, 0.97) 60%, transparent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }

  nav.scrolled {
    background: rgba(12, 9, 4, 0.97);
    border-bottom-color: var(--border);
  }

  .nav-brand {
    font-family: 'EB Garamond', serif;
    font-size: 1.05rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--parch-lt);
    text-decoration: none;
    transition: color 0.25s;
  }
  .nav-brand:hover { color: var(--text); }

  .nav-links {
    display: flex;
    gap: 0;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    display: block;
    padding: 0.5rem 1.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
    text-decoration: none;
    transition: color 0.25s;
  }
  .nav-links a:hover,
  .nav-links a.active { color: var(--parch-lt); }

  .nav-discord a {
    border: 1px solid var(--border);
    color: var(--parch) !important;
    margin-left: 1rem;
    transition: border-color 0.25s, background 0.25s !important;
  }
  .nav-discord a:hover {
    border-color: var(--parch) !important;
    background: rgba(155, 127, 90, 0.08);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--parch);
    transition: transform 0.25s, opacity 0.25s;
  }
  .nav-toggle.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  @media (max-width: 768px) {
    .nav-toggle { display: flex; }
    .nav-links {
      display: none;
      position: fixed;
      top: var(--nav-h); left: 0; right: 0;
      flex-direction: column;
      background: rgba(12, 9, 4, 0.98);
      border-bottom: 1px solid var(--border);
      padding: 1.5rem 0;
      gap: 0.5rem;
    }
    .nav-links.open { display: flex; }
    .nav-links a { padding: 0.75rem 2rem; }
    .nav-discord { margin: 0 2rem; }
    .nav-discord a { margin-left: 0 !important; text-align: center; }
  }
</style>

<script>
  const nav = document.querySelector('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });
</script>
