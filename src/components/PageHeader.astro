---
export interface Props {
  label: string;
  title: string;
  subtitle?: string;
  ghost?: string;
}
const { label, title, subtitle, ghost } = Astro.props;
---

<header class="page-header">
  <div class="page-header-glow"></div>
  {ghost && <div class="page-header-ghost" aria-hidden="true">{ghost}</div>}
  <div class="section-label">{label}</div>
  <h1>{title}</h1>
  {subtitle && <p class="page-header-sub">{subtitle}</p>}
</header>

<style>
  .page-header {
    min-height: 55vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: calc(var(--nav-h) + 4rem) var(--section-px) 5rem;
    position: relative;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .page-header-glow {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 20% 80%, rgba(155,127,90,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .page-header-ghost {
    position: absolute;
    right: clamp(1rem, 4vw, 4rem);
    bottom: 3rem;
    font-family: 'EB Garamond', serif;
    font-size: clamp(5rem, 14vw, 12rem);
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--parch);
    opacity: 0.04;
    pointer-events: none;
    white-space: nowrap;
    line-height: 1;
    user-select: none;
    text-transform: uppercase;
  }

  h1 {
    font-family: 'EB Garamond', serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 400;
    max-width: 1100px;
    margin-bottom: 1rem;
    position: relative;
  }

  .page-header-sub {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 1.2rem;
    color: var(--dim);
    max-width: 580px;
    position: relative;
  }

  @media (max-width: 640px) {
    .page-header {
      min-height: 38vh;
      padding-top: calc(var(--nav-h) + 2rem);
      padding-bottom: 3rem;
    }
    h1 { font-size: clamp(2.4rem, 12vw, 4rem); }
    .page-header-sub { font-size: 1rem; max-width: 100%; }
    .page-header-ghost { font-size: clamp(2.6rem, 22vw, 4.5rem); bottom: 1.5rem; }
  }
</style>
